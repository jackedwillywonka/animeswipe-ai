# Copy this file to .env and fill in your real values.
# Never commit the real .env file.

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# URL of your deployed Supabase Edge Function that proxies OpenAI calls.
# Do NOT put your OpenAI key directly in this app - see src/services/aiService.ts
EXPO_PUBLIC_AI_PROXY_URL=https://your-project.functions.supabase.co/ai-proxy
